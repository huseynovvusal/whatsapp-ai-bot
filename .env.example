# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# WhatsApp Bot Configuration
BOT_NAME=@bot
ADMIN_NUMBERS=1234567890,9876543210

# LLM Configuration
LLM_PROVIDER=gemini

# OpenAI (if using OpenAI)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini (if using Gemini)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Memory Configuration
MEMORY_WINDOW_MS=3600000

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=2
RATE_LIMIT_WINDOW_MS=60000

# System Prompt
SYSTEM_PROMPT=Your custom system prompt goes here.

# Enable private chat responses (true/false)
ENABLE_PRIVATE_CHAT=false
